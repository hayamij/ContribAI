  # Auto-merge when all CI passes + Copilot/manual approval
  - name: Auto-merge on CI pass + approval
    conditions:
      - check-success=CI / Lint & Format
      - check-success=CI / Test (Python 3.11)
      - check-success=CI / Test (Python 3.12)
      - check-success=CI / Test (Python 3.13)
      - check-success=CI / Security Check
      - "#approved-reviews-by>=1"
      - -draft
      - -conflict
    actions:
      merge:
        method: merge
        commit_message_template: |
          {{ title }} (#{{ number }})

          {{ body }}

  # Auto-close stale PRs (no activity for 14 days)
  - name: Close stale PRs
    conditions:
      - updated-at<14 days ago
      - -merged
      - -closed
    actions:
      comment:
        message: |
          This PR has been inactive for 14 days. Closing for housekeeping.
          Feel free to reopen if you'd like to continue working on it.
      close:
        message: Closed due to inactivity.

  # Label PRs by CI status
  - name: Label CI-passing PRs
    conditions:
      - check-success=CI / Lint & Format
      - check-success=CI / Test (Python 3.11)
      - check-success=CI / Test (Python 3.12)
      - check-success=CI / Test (Python 3.13)
    actions:
      label:
        add:
          - "ci-passing"

  - name: Label CI-failing PRs
    conditions:
      - or:
